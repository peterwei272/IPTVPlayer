<Window x:Class="IPTVPlayer.App.SourceManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理订阅源与 EPG 源"
        Width="1280"
        Height="780"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Padding="14"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Text="M3U 订阅源" />
                    <DataGrid x:Name="PlaylistGrid"
                              Grid.Row="1"
                              Margin="0,14,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              ItemsSource="{Binding PlaylistSources}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding Enabled}" Header="启用" Width="70" />
                            <DataGridTextColumn Binding="{Binding Name}" Header="名称" Width="170" />
                            <DataGridTextColumn Binding="{Binding Url}" Header="URL" Width="*" />
                            <DataGridCheckBoxColumn Binding="{Binding RefreshOnStartup}" Header="启动刷新" Width="90" />
                            <DataGridTextColumn Binding="{Binding LastRefreshDisplayText}" Header="上次刷新" Width="170" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                <Button Click="AddPlaylist_Click" Content="新增" />
                <Button Click="RemovePlaylist_Click" Content="删除" />
                <Button Click="MovePlaylistUp_Click" Content="上移" />
                <Button Click="MovePlaylistDown_Click" Content="下移" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Padding="14"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Text="EPG 源" />
                    <DataGrid x:Name="EpgGrid"
                              Grid.Row="1"
                              Margin="0,14,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              ItemsSource="{Binding EpgSources}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding Enabled}" Header="启用" Width="70" />
                            <DataGridTextColumn Binding="{Binding Name}" Header="名称" Width="170" />
                            <DataGridTextColumn Binding="{Binding Url}" Header="URL" Width="*" />
                            <DataGridCheckBoxColumn Binding="{Binding RefreshOnStartup}" Header="启动刷新" Width="90" />
                            <DataGridTextColumn Binding="{Binding FormatHint}" Header="格式" Width="110" />
                            <DataGridTextColumn Binding="{Binding LastRefreshDisplayText}" Header="上次刷新" Width="170" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                <Button Click="AddEpg_Click" Content="新增" />
                <Button Click="RemoveEpg_Click" Content="删除" />
                <Button Click="MoveEpgUp_Click" Content="上移" />
                <Button Click="MoveEpgDown_Click" Content="下移" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Click="Cancel_Click" Content="取消" />
            <Button Click="Save_Click" Content="保存并刷新" />
        </StackPanel>
    </Grid>
</Window>
