<Window x:Class="IPTVPlayer.App.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:media="clr-namespace:IPTVPlayer.App.Services.Media"
        mc:Ignorable="d"
        Title="IPTV 播放器"
        Width="1640"
        Height="960"
        MinWidth="1280"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid x:Name="RootLayout" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="TopBar"
                Grid.Row="0"
                Padding="18"
                Margin="0,0,0,14"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock FontSize="26"
                           FontWeight="SemiBold"
                           Text="IPTV 播放器"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Command="{Binding RefreshCommand}" Content="刷新订阅与 EPG" />
                    <Button Click="OpenSourceManager_Click" Content="管理源" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="MainContentGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ChannelColumn" Width="320" />
                <ColumnDefinition x:Name="PlayerColumn" Width="*" />
                <ColumnDefinition x:Name="ProgrammeColumn" Width="360" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ChannelPane"
                    Grid.Column="0"
                    Padding="16"
                    Margin="0,0,14,0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBox x:Name="SearchBox"
                                 Padding="12,8"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center" />
                        <TextBlock Margin="12,0,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   IsHitTestVisible="False"
                                   Text="搜索频道"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <ComboBox Grid.Row="1"
                              Margin="0,14,0,14"
                              ItemsSource="{Binding Groups}"
                              SelectedItem="{Binding SelectedGroup}" />

                    <ListBox Grid.Row="2"
                             x:Name="ChannelList"
                             ItemsSource="{Binding Channels}"
                             SelectedItem="{Binding SelectedChannel}"
                             SelectionChanged="ChannelList_SelectionChanged"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ChannelCard"
                                        Padding="10"
                                        Margin="4"
                                        CornerRadius="12"
                                        Background="{StaticResource ItemBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="52" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="42"
                                                Height="42"
                                                Background="{StaticResource PanelAltBrush}"
                                                CornerRadius="10">
                                            <Image Width="32"
                                                   Height="32"
                                                   Stretch="Uniform"
                                                   Source="{Binding LogoUrl}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding DisplayName}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Text="{Binding GroupTitle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="ChannelCard" Property="Background" Value="{StaticResource ItemSelectedBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="ChannelCard" Property="Background" Value="{StaticResource ItemHoverBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border x:Name="PlayerPane"
                    Grid.Column="1"
                    Padding="16"
                    Margin="0,0,14,0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel x:Name="PlayerHeader" Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Text="{Binding CurrentChannelName}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   Text="单击频道立即播放，双击画面或 F11 全屏，方向键切台，Enter 播放，F5 刷新" />
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding VideoTechnicalSummary}" />
                    </StackPanel>

                    <Border x:Name="PlayerSurfaceBorder"
                            Grid.Row="1"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <Grid>
                            <media:MpvHost x:Name="PlayerHost" />
                            <Grid Background="Transparent"
                                  MouseLeftButtonDown="PlayerSurface_MouseLeftButtonDown">
                                <Grid Margin="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Padding="14,10"
                                            Background="{StaticResource OverlayBrush}"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding CurrentChannelName}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Text="{Binding CurrentProgrammeTime}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Text="{Binding CurrentProgrammeTitle}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Padding="14,10"
                                            MaxWidth="360"
                                            Background="{StaticResource OverlayBrush}"
                                            CornerRadius="14">
                                        <TextBlock Foreground="White"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding VideoTechnicalSummary}" />
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="ProgrammePane"
                    Grid.Column="2"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Text="当前与未来节目" />

                    <ListBox Grid.Row="1"
                             Margin="0,14,0,0"
                             ItemsSource="{Binding UpcomingProgrammes}"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12"
                                        Margin="4"
                                        Background="{StaticResource ItemBrush}"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Title}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource AccentAltBrush}"
                                                   Text="{Binding ScheduleText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Description}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
